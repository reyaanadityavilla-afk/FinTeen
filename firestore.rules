rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stats/global {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['learnersJoined'])
                    && request.resource.data.learnersJoined == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['learnersJoined'])
                    && request.resource.data.learnersJoined
                       == resource.data.learnersJoined + 1;
      allow delete: if false;
    }

    match /learners/{learnerId} {
      allow read: if false;
      allow create: if !exists(/databases/$(database)/documents/learners/$(learnerId))
                    && request.resource.data.keys().hasOnly(['name', 'joinedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.name.size() <= 80
                    && request.resource.data.joinedAt == request.time;
      allow update, delete: if false;
    }
  }
}
